// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  clerkUserId  String?  @unique
  email        String   @unique
  name         String
  imageUrl     String?
  subscription String   @default("free")
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  trips           Trip[]
  reminders       Reminder[]
  analyticsEvents AnalyticsEvent[]

  @@map("users")
}

model Trip {
  id          String   @id @default(cuid())
  budget      String?
  destination String
  duration    String?
  groupSize   String?
  origin      String?
  plan        Json?
  planHash    String?
  budgetAmount Int?
  durationDays Int?
  isFavorite Boolean  @default(false)
  lastViewedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotels Hotel[]
  itineraryItems ItineraryItem[]
  reminders Reminder[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite, createdAt(sort: Desc)])
  @@index([userId, budgetAmount])
  @@index([userId, durationDays])
  @@index([userId, destination])
  @@index([destination])
  @@unique([userId, planHash])
  @@map("trips")
}

model Reminder {
  id        String   @id @default(cuid())
  type      String
  message   String
  remindAt  DateTime
  status    String   @default("scheduled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tripId String?
  trip   Trip? @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, status, remindAt])
  @@index([tripId])
  @@map("reminders")
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  destination String?
  success     Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([destination, createdAt])
  @@index([userId, createdAt])
  @@map("analytics_events")
}

model Hotel {
  id            String   @id @default(cuid())
  name          String
  pricePerNight String
  rating        Float
  amenities     String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([tripId, rating])
  @@map("hotels")
}

model ItineraryItem {
  id         String   @id @default(cuid())
  day        Int
  activities String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, day])
  @@map("itinerary_items")
}
